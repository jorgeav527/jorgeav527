---
import { Icon } from 'astro-icon/components';
---

<nav class="flex flex-col md:flex-row items-center justify-between py-4 px-6 text-lg font-semibold text-gray-700 space-y-4 md:space-y-0">
    <!-- Left Navigation Links with Button Style -->
    <div class="flex space-x-4">
        <a href="/" class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500">Home</a>
        <a href="/about/" class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500">About</a>
        <a href="/blog/" class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500">Blog</a>
    </div>

    <!-- Right Social Links styled as buttons using astro-icon -->
    <div class="flex space-x-4">
        <a href="https://www.linkedin.com/in/jorgeav527" target="_blank" rel="noopener noreferrer"
           class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500"
           aria-label="LinkedIn">
            <Icon name="mdi:linkedin" class="w-6 h-6" />
        </a>
        <a href="https://github.com/jorgeav527" target="_blank" rel="noopener noreferrer"
           class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500"
           aria-label="GitHub">
            <Icon name="mdi:github" class="w-6 h-6" />
        </a>
        <a href="https://www.instagram.com/jorgeav527" target="_blank" rel="noopener noreferrer"
           class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500"
           aria-label="Instagram">
            <Icon name="mdi:instagram" class="w-6 h-6" />
        </a>
        <a href="https://www.youtube.com/@jorgeav527-xyz" target="_blank" rel="noopener noreferrer"
           class="px-4 py-2 text-white bg-gray-800 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500"
           aria-label="Instagram">
            <Icon name="mdi:youtube" class="w-6 h-6" />
        </a>
    </div>
</nav>
